#: apwg-gateway.php:50
msgid "Settings"
msgstr "Cài đặt"

#: includes/class-polar-gateway.php:23
msgid "Polar"
msgstr "Polar"

#: includes/class-polar-gateway.php:24
msgid "Accept payments via Polar.sh Checkout"
msgstr "Chấp nhận thanh toán qua Polar.sh Checkout"

#: includes/class-polar-gateway.php:47
msgid "Enable/Disable"
msgstr "Kích hoạt/Vô hiệu hóa"

#: includes/class-polar-gateway.php:49
msgid "Enable Polar Payment Gateway"
msgstr "Kích hoạt Cổng thanh toán Polar"

#: includes/class-polar-gateway.php:52
msgid "Title"
msgstr "Tiêu đề"

#: includes/class-polar-gateway.php:54
msgid "Payment method title that customers will see during checkout."
msgstr "Tiêu đề phương thức thanh toán mà khách hàng sẽ thấy khi thanh toán."

#: includes/class-polar-gateway.php:55
msgid "Credit/Debit Card"
msgstr "Thẻ tín dụng/ghi nợ"

#: includes/class-polar-gateway.php:59
msgid "Description"
msgstr "Mô tả"

#: includes/class-polar-gateway.php:61
msgid "Payment method description that customers will see during checkout."
msgstr "Mô tả phương thức thanh toán mà khách hàng sẽ thấy khi thanh toán."

#: includes/class-polar-gateway.php:62
msgid "Pay securely with credit or debit card. You will be redirected to our secure payment page."
msgstr "Thanh toán an toàn bằng thẻ tín dụng/ghi nợ. Bạn sẽ được chuyển hướng đến trang thanh toán bảo mật của chúng tôi."

#: includes/class-polar-gateway.php:66
msgid "Polar Access Token"
msgstr "Mã truy cập Polar"

#: includes/class-polar-gateway.php:68
msgid "Enter your Access Token from Polar.sh Dashboard."
msgstr "Nhập Mã truy cập (Access Token) từ Bảng điều khiển Polar.sh."

#: includes/class-polar-gateway.php:73
msgid "Product Mapping"
msgstr "Ánh xạ sản phẩm"

#: includes/class-polar-gateway.php:75
msgid "Choose how to map WooCommerce products to Polar Product IDs. Recommended: \"Single Product + Dynamic Pricing\""
msgstr "Chọn cách ánh xạ sản phẩm WooCommerce với ID Sản phẩm Polar. Khuyến nghị: \"Sản phẩm đơn + Giá động\""

#: includes/class-polar-gateway.php:78
msgid "Single Product + Dynamic Pricing (Recommended)"
msgstr "Sản phẩm đơn + Giá động (Khuyến nghị)"

#: includes/class-polar-gateway.php:79
msgid "Single Product (Use catalog price)"
msgstr "Sản phẩm đơn (Sử dụng giá catalog)"

#: includes/class-polar-gateway.php:80
msgid "From Product Meta Field"
msgstr "Từ trường Meta của sản phẩm"

#: includes/class-polar-gateway.php:85
msgid "Default Polar Product ID"
msgstr "ID Sản phẩm Polar mặc định"

#: includes/class-polar-gateway.php:87
msgid "Default Product ID when using \"Single Product\" modes."
msgstr "ID Sản phẩm mặc định khi sử dụng chế độ \"Sản phẩm đơn\"."

#: includes/class-polar-gateway.php:92
msgid "Test Mode"
msgstr "Chế độ thử nghiệm"

#: includes/class-polar-gateway.php:94
msgid "Enable test mode"
msgstr "Bật chế độ thử nghiệm"

#: includes/class-polar-gateway.php:96
msgid "Use for testing during development."
msgstr "Sử dụng để kiểm tra trong quá trình phát triển."

#: includes/class-polar-gateway.php:99
msgid "Debug Log"
msgstr "Nhật ký gỡ lỗi"

#: includes/class-polar-gateway.php:101
msgid "Enable logging"
msgstr "Bật ghi nhật ký"

#: includes/class-polar-gateway.php:103
#, php-format
msgid "Save logs to %s"
msgstr "Lưu nhật ký vào %s"

#: includes/class-polar-gateway.php:121
msgid "Unable to create checkout session with Polar."
msgstr "Không thể tạo phiên thanh toán với Polar."

#: includes/class-polar-gateway.php:130
msgid "Awaiting payment via Polar."
msgstr "Đang chờ thanh toán qua Polar."

#: includes/class-polar-gateway.php:140
msgid "Payment error: "
msgstr "Lỗi thanh toán: "

#: includes/class-polar-gateway.php:156
msgid "Polar Access Token is not configured."
msgstr "Mã truy cập Polar chưa được cấu hình."

#: includes/class-polar-gateway.php:226
msgid "Default Product ID is not configured."
msgstr "ID Sản phẩm mặc định chưa được cấu hình."

#: includes/class-polar-gateway.php:252
msgid "Default Product ID is not configured. Please create a Product on Polar and enter its ID in Settings."
msgstr "ID Sản phẩm mặc định chưa được cấu hình. Vui lòng tạo Sản phẩm trên Polar và nhập ID của nó vào Cài đặt."

#: includes/class-polar-gateway.php:292
msgid "No Polar Product ID found in products."
msgstr "Không tìm thấy ID Sản phẩm Polar trong các sản phẩm."

#: includes/class-polar-gateway.php:334
msgid "Payment confirmed via Polar."
msgstr "Thanh toán đã được xác nhận qua Polar."

#: includes/class-polar-gateway.php:352
msgid "You will be redirected to Polar payment page..."
msgstr "Bạn sẽ được chuyển hướng đến trang thanh toán Polar..."

msgid "Polar Payment Settings"
msgstr "Cài đặt thanh toán Polar"

msgid "Enable Polar Subscription"
msgstr "Bật thanh toán theo gói"

msgid "Check this if this product should be sold as a subscription via Polar."
msgstr "Chọn nếu sản phẩm này được bán theo gói đăng ký qua Polar."

msgid "Polar Product ID"
msgstr "ID Sản phẩm Polar"

msgid "Enter the Polar Product ID for this product. Required if subscription is enabled or using \"From Product Meta Field\" mapping."
msgstr "Nhập ID Sản phẩm Polar cho sản phẩm này. Bắt buộc nếu bật đăng ký hoặc dùng chế độ \"Từ trường Meta\"."

msgid "Product \"%s\" is marked as subscription but has no Polar Product ID. Please configure it in the product settings."
msgstr "Sản phẩm \"%s\" được đánh dấu là gói đăng ký nhưng chưa có ID Sản phẩm Polar. Vui lòng cấu hình trong cài đặt sản phẩm."

msgid "Subscription created and payment confirmed via Polar."
msgstr "Gói đăng ký đã được tạo và thanh toán đã được xác nhận qua Polar."
